@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap');

:root {
  --primary: #fc8019;
  --primary-hover: #ff9138;
  --bg-dark: #0a0a0c;
  --card-bg: rgba(25, 25, 28, 0.6);
  --text-main: #ffffff;
  --text-sec: #9ea0ab;
}

body {
  margin: 0;
  font-family: 'Outfit', -apple-system, sans-serif;
  background-color: var(--bg-dark);
  color: var(--text-main);
  -webkit-font-smoothing: antialiased;
}

.App {
  min-height: 100vh;
}

/* Navbar */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  padding: 15px 50px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(10, 10, 12, 0.8);
  backdrop-filter: blur(12px);
  z-index: 1000;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.navbar h1 {
  margin: 0;
  font-size: 1.8rem;
  font-weight: 800;
  background: linear-gradient(90deg, #fff, #9ea0ab);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.cart-toggle {
  background: var(--primary);
  color: #fff;
  border: none;
  padding: 10px 25px;
  border-radius: 30px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(252, 128, 25, 0.3);
}

.cart-toggle:hover {
  background: var(--primary-hover);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(252, 128, 25, 0.4);
}

/* Hero */
.hero {
  position: relative;
  height: 500px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-image: url('./hero.png');
  background-size: cover;
  background-position: center;
  margin-top: 50px;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(10,10,12,0.3) 0%, rgba(10,10,12,0.9) 100%);
}

.hero-content {
  position: relative;
  z-index: 10;
  text-align: center;
  max-width: 800px;
  padding: 0 20px;
}

.hero h2 {
  font-size: 4rem;
  margin: 0 0 10px;
  font-weight: 800;
  letter-spacing: -1px;
}

.hero p {
  font-size: 1.2rem;
  color: var(--text-sec);
  margin-bottom: 40px;
}

/* Form Search Bar */
form {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  padding: 20px;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
}

.form-group {
  flex: 1;
  min-width: 150px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  text-align: left;
}

.form-group label {
  font-size: 0.85rem;
  color: var(--text-sec);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
}

input, select {
  padding: 12px 15px;
  background: rgba(0,0,0,0.3);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  color: white;
  font-size: 1rem;
  font-family: inherit;
  transition: all 0.3s ease;
}

input:focus, select:focus {
  outline: none;
  border-color: var(--primary);
  background: rgba(0,0,0,0.5);
}

select option {
  background: var(--bg-dark);
  color: white;
}

.submit-btn {
  background: var(--primary);
  color: white;
  border: none;
  padding: 0 30px;
  border-radius: 12px;
  font-weight: 600;
  font-size: 1.1rem;
  cursor: pointer;
  transition: all 0.3s;
  height: 44px;
  align-self: flex-end;
}

.submit-btn:hover {
  background: var(--primary-hover);
  transform: translateY(-2px);
}
.submit-btn:disabled {
  background: #333;
  color: #777;
  cursor: not-allowed;
  transform: none;
}

main {
  max-width: 1300px;
  margin: 0 auto;
  padding: 40px 20px;
}

.section-title {
  font-size: 2rem;
  font-weight: 800;
  margin-bottom: 30px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  padding-bottom: 15px;
}

.section-title span {
  font-size: 1rem;
  color: var(--primary);
  font-weight: 600;
}

.meals-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 30px;
}

.meal-card {
  background: var(--card-bg);
  border-radius: 20px;
  padding: 25px;
  border: 1px solid rgba(255,255,255,0.05);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  overflow: hidden;
}

.meal-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--primary), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.meal-card:hover {
  transform: translateY(-10px);
  border-color: rgba(255,255,255,0.15);
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}

.meal-card:hover::before {
  opacity: 1;
}

.meal-rank {
  position: absolute;
  top: 20px;
  right: 20px;
  font-size: 2rem;
  font-weight: 800;
  color: rgba(255,255,255,0.05);
}

.meal-card h4 {
  font-size: 1.4rem;
  margin: 0 0 5px;
  color: var(--text-main);
  padding-right: 30px;
}

.restaurant-label {
  font-size: 0.9rem;
  color: var(--text-main);
  background: rgba(255,255,255,0.1);
  padding: 4px 10px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 12px;
  font-weight: 600;
}

.meal-category {
  color: var(--primary);
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 20px;
}

.macros {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 25px;
}

.macro-box {
  background: rgba(0,0,0,0.3);
  padding: 10px;
  border-radius: 10px;
}

.macro-box span {
  display: block;
  font-size: 0.75rem;
  color: var(--text-sec);
  text-transform: uppercase;
  margin-bottom: 4px;
}

.macro-box strong {
  font-size: 1.1rem;
}

.meal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 15px;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.05);
}

.meal-price {
  font-size: 1.5rem;
  font-weight: 800;
}

.add-btn {
  background: transparent;
  color: var(--primary);
  border: 1px solid var(--primary);
  padding: 8px 20px;
  border-radius: 20px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
}

.add-btn:hover {
  background: var(--primary);
  color: white;
}

.orders-section {
  margin-top: 80px;
}

.order-item {
  background: var(--card-bg);
  padding: 20px;
  border-radius: 15px;
  margin-bottom: 15px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1px solid rgba(255,255,255,0.05);
}

.order-meta {
  color: var(--text-sec);
  font-size: 0.9rem;
}

.order-desc {
  font-weight: 600;
  margin-top: 5px;
}

/* Cart Panel overlay*/
.cart-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(5px);
  z-index: 2000;
}

.cart-panel {
  background: var(--bg-dark);
  width: 100%;
  max-width: 450px;
  height: 100vh;
  padding: 30px;
  box-sizing: border-box;
  box-shadow: -10px 0 30px rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 2001;
  border-left: 1px solid rgba(255,255,255,0.1);
  overflow-y: auto;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--card-bg);
  padding: 15px;
  border-radius: 12px;
  margin-bottom: 10px;
}

.quantity-controls {
  display: flex;
  align-items: center;
  gap: 10px;
}

.quantity-controls button {
  background: rgba(255,255,255,0.1);
  color: white;
  border: none;
  width: 30px;
  height: 30px;
  border-radius: 15px;
  cursor: pointer;
}

.quantity-controls button:hover {
  background: var(--primary);
}

.cart-footer {
  margin-top: auto;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.1);
}

.checkout-btn {
  width: 100%;
  background: var(--primary);
  color: white;
  padding: 15px;
  border: none;
  border-radius: 12px;
  font-weight: bold;
  font-size: 1.1rem;
  margin-top: 15px;
  cursor: pointer;
  transition: all 0.3s;
}

.checkout-btn:hover {
  background: var(--primary-hover);
}

.checkout-btn:disabled {
  background: #333;
  cursor: not-allowed;
}

/* Payment Display */
.payment-overlay {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  text-align: center;
}

.spinner {
  width: 50px;
  height: 50px;
  border: 4px solid rgba(255,255,255,0.1);
  border-left-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20px;
}

@keyframes spin {
  100% { transform: rotate(360deg); }
}

.payment-success {
  background: #27ae60;
  color: #fff;
  padding: 20px;
  border-radius: 50%;
  width: 80px;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
  margin-bottom: 20px;
}

/* Login UI */
.login-overlay {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: url('./hero.png') center/cover;
  z-index: 3000;
}

.login-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(10, 10, 12, 0.85);
  backdrop-filter: blur(15px);
}

.login-card {
  position: relative;
  z-index: 3001;
  background: rgba(255, 255, 255, 0.05);
  padding: 40px;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  width: 100%;
  max-width: 400px;
  text-align: center;
  box-shadow: 0 30px 60px rgba(0,0,0,0.5);
  box-sizing: border-box;
}

.login-card h2 {
  font-size: 2rem;
  margin: 0 0 5px;
  color: var(--primary);
  font-weight: 800;
  background: linear-gradient(90deg, #fc8019, #feca57);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.login-card p {
  color: var(--text-sec);
  margin-bottom: 30px;
}

.login-card form {
  background: transparent;
  box-shadow: none;
  border: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 15px;
  margin: 0;
}

.login-card input {
  box-sizing: border-box;
  width: 100%;
}

.login-card .submit-btn {
  width: 100%;
  margin-top: 10px;
}

/* Swiggy Bottom Cart */
.swiggy-bottom-cart {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #60b246;
  color: white;
  padding: 15px 50px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  z-index: 1500;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.5);
  font-weight: 800;
  font-size: 1.1rem;
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.swiggy-bottom-cart:hover {
  background: #509e37;
  padding-bottom: 20px;
}

.cart-summary-text {
  display: flex;
  gap: 15px;
}

.view-cart-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

/* User Profile Modal + Address */
.profile-modal {
  position: absolute;
  top: 70px;
  right: 50px;
  background: rgba(10, 10, 12, 0.95);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.15);
  padding: 20px;
  border-radius: 12px;
  box-shadow: 0 15px 40px rgba(0,0,0,0.7);
  width: 280px;
  z-index: 2000;
}

.profile-modal h4 {
  margin: 0 0 15px;
  color: var(--primary);
  border-bottom: 1px solid rgba(255,255,255,0.05);
  padding-bottom: 10px;
  font-size: 1.2rem;
}

.address-box {
  background: rgba(255,255,255,0.05);
  padding: 15px;
  border-radius: 8px;
  font-size: 0.95rem;
  margin-bottom: 20px;
  color: var(--text-sec);
  line-height: 1.4;
}

.logout-btn {
  background: transparent;
  color: #ff6b6b;
  border: 1px solid #ff6b6b;
  width: 100%;
  padding: 10px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s;
}

.logout-btn:hover {
  background: #ff6b6b;
  color: white;
}
